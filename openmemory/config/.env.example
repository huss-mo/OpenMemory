# OpenMemory — Environment Variable Reference
# Copy this file to .env in your config directory and fill in your values.
#
# Config file locations (first match wins):
#   ~/.openmemory/.env   ← pip / editable installs (recommended)
#   ./data/.env          ← Docker (host path, mounted at /data)
#   ./.env               ← cwd override / dev mode
#
# Environment variables take priority over openmemory.yaml.
# Use double-underscore (__) for nested config keys.

# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------

# Root directory for all workspaces (default: ~/.openmemory)
# OPENMEMORY_ROOT_DIR=~/.openmemory

# Default workspace name (default: "default")
# OPENMEMORY_WORKSPACE=default

# ---------------------------------------------------------------------------
# MCP server (openmemory-mcp command)
# ---------------------------------------------------------------------------

# Host address the MCP server binds to (default: 0.0.0.0)
# OPENMEMORY_MCP__HOST=0.0.0.0

# TCP port the MCP server listens on (default: 4242)
# OPENMEMORY_MCP__PORT=4242

# ---------------------------------------------------------------------------
# Embedding provider
# ---------------------------------------------------------------------------
# PROVIDER options:
#   "none"   — BM25 keyword search only (no embeddings, no vector search) [default]
#   "openai" — OpenAI-compatible HTTP API (OpenAI, Ollama, LM Studio, etc.)
#   "local"  — sentence-transformers (requires: pip install openmemory[local])

OPENMEMORY_EMBEDDING__PROVIDER=none

# --- local (sentence-transformers) ---
# Model name from https://www.sbert.net/docs/pretrained_models.html
# OPENMEMORY_EMBEDDING__LOCAL_MODEL=all-MiniLM-L6-v2

# --- openai / OpenAI-compatible API ---
# Leave BASE_URL empty to use the real OpenAI API.
# Set BASE_URL to point at a local server (Ollama, LM Studio, vLLM, etc.)
# OPENMEMORY_EMBEDDING__BASE_URL=http://localhost:11434/v1
# OPENMEMORY_EMBEDDING__API_KEY=sk-...
# OPENMEMORY_EMBEDDING__MODEL=text-embedding-3-small

# Number of texts per embedding API call
# OPENMEMORY_EMBEDDING__BATCH_SIZE=64

# ---------------------------------------------------------------------------
# Search
# ---------------------------------------------------------------------------

# Number of results returned by memory_search
# OPENMEMORY_SEARCH__TOP_K=6

# Oversampling factor (candidates = top_k * candidate_multiplier per path)
# OPENMEMORY_SEARCH__CANDIDATE_MULTIPLIER=4

# Weight for vector similarity vs. BM25 keyword score (0.0–1.0)
# 0.0 = pure keyword, 1.0 = pure vector
# OPENMEMORY_SEARCH__VECTOR_WEIGHT=0.7

# Temporal decay rate per day (0.0 = disabled)
# score *= exp(-decay_rate * days_old)
# OPENMEMORY_SEARCH__TEMPORAL_DECAY_RATE=0.0

# MMR diversity lambda (0.0 = disabled, 1.0 = maximum diversity)
# OPENMEMORY_SEARCH__MMR_LAMBDA=0.0

# ---------------------------------------------------------------------------
# Chunking
# ---------------------------------------------------------------------------

# Target chunk size in approximate tokens (1 token ≈ 4 chars)
# OPENMEMORY_CHUNKING__TOKENS=400

# Overlap between consecutive chunks in approximate tokens
# OPENMEMORY_CHUNKING__OVERLAP=80

# ---------------------------------------------------------------------------
# Bootstrap (system-prompt injection)
# ---------------------------------------------------------------------------

# Max characters per file before a truncation warning is added
# OPENMEMORY_BOOTSTRAP__MAX_CHARS_PER_FILE=20000

# Max total characters across all injected files
# OPENMEMORY_BOOTSTRAP__MAX_TOTAL_CHARS=150000

# Which files to inject into the system prompt at session start
# OPENMEMORY_BOOTSTRAP__INJECT_LONG_TERM_MEMORY=true
# OPENMEMORY_BOOTSTRAP__INJECT_USER_PROFILE=true
# OPENMEMORY_BOOTSTRAP__INJECT_AGENTS=true
# OPENMEMORY_BOOTSTRAP__INJECT_DAILY_LOGS=true
# OPENMEMORY_BOOTSTRAP__INJECT_RELATIONS=true

# Reconcile the SQLite relations table from RELATIONS.md at session start.
# Enable this if you edit RELATIONS.md manually outside the agent (e.g. in a
# text editor or via git) so that changes are reflected at the next session start.
# Disabled by default — the agent keeps both stores in sync automatically.
# OPENMEMORY_BOOTSTRAP__SYNC_RELATIONS_ON_BOOTSTRAP=false

# ---------------------------------------------------------------------------
# Compaction (pre-context-window-flush hooks)
# ---------------------------------------------------------------------------

# Enable compaction detection hooks
# OPENMEMORY_COMPACTION__ENABLED=true

# Tokens remaining in context window that trigger a flush suggestion
# OPENMEMORY_COMPACTION__SOFT_THRESHOLD_TOKENS=4000

# Minimum tokens always kept free for model responses
# OPENMEMORY_COMPACTION__RESERVE_FLOOR_TOKENS=20000