# GroundMemory - Environment Variable Reference
# Copy this file to .env in your config directory and fill in your values.
#
# Config file locations (first match wins):
#   ~/.groundmemory/.env   <- pip / editable installs (recommended)
#   ./data/.env            <- Docker (host path, mounted at /data)
#   ./.env                 <- cwd override / dev mode
#
# Environment variables take priority over groundmemory.yaml.
# Use double-underscore (__) for nested config keys.
# All variable names are uppercase: GROUNDMEMORY_<SECTION>__<FIELD>

# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------

# Root directory for all workspaces (default: ~/.groundmemory)
# GROUNDMEMORY_ROOT_DIR=~/.groundmemory

# Default workspace name (default: "default")
# GROUNDMEMORY_WORKSPACE=default

# ---------------------------------------------------------------------------
# MCP server (groundmemory-mcp command)
# ---------------------------------------------------------------------------

# Host address the MCP server binds to (default: 127.0.0.1 - localhost only).
# Change to 0.0.0.0 to accept connections from other machines on your network.
# See "Network access" below before changing this.
# GROUNDMEMORY_MCP__HOST=127.0.0.1

# TCP port the MCP server listens on (default: 4242)
# GROUNDMEMORY_MCP__PORT=4242

# ---------------------------------------------------------------------------
# Network access
# ---------------------------------------------------------------------------
# By default the server is localhost-only. To allow access from other devices
# on your local network, uncomment and set HOST and ALLOWED_HOSTS together.
#
# GROUNDMEMORY_MCP__HOST: bind address. Set to 0.0.0.0 for LAN access.
# GROUNDMEMORY_MCP__ALLOWED_HOSTS: DNS-rebinding protection allowlist.
#   List every "host:port" value clients will use in the Host: header.
#   localhost and 127.0.0.1 are always allowed implicitly.
#   Separate multiple values with commas.
#
# Example - LAN access:
# GROUNDMEMORY_MCP__HOST=0.0.0.0
# GROUNDMEMORY_MCP__ALLOWED_HOSTS=192.168.1.50:4242
#
# GROUNDMEMORY_MCP__FORWARDED_ALLOW_IPS: only needed when running behind a
#   reverse proxy (nginx, Caddy, Traefik). Set to the proxy's internal IP so
#   uvicorn trusts the X-Forwarded-For / X-Real-IP headers it sends.
#   Leave unset for direct LAN access (no proxy in front of GroundMemory).
# GROUNDMEMORY_MCP__FORWARDED_ALLOW_IPS=127.0.0.1

# ---------------------------------------------------------------------------
# Embedding provider
# ---------------------------------------------------------------------------
# PROVIDER options:
#   "none"   — BM25 keyword search only (no embeddings, no vector search) [default]
#   "openai" — OpenAI-compatible HTTP API (OpenAI, Ollama, LM Studio, etc.)
#   "local"  — sentence-transformers (requires: pip install groundmemory[local])

GROUNDMEMORY_EMBEDDING__PROVIDER=none

# --- local (sentence-transformers) ---
# Model name from https://www.sbert.net/docs/pretrained_models.html
# GROUNDMEMORY_EMBEDDING__LOCAL_MODEL=all-MiniLM-L6-v2

# --- openai / OpenAI-compatible API ---
# Leave BASE_URL empty to use the real OpenAI API.
# Set BASE_URL to point at a local server (Ollama, LM Studio, vLLM, etc.)
# GROUNDMEMORY_EMBEDDING__BASE_URL=http://localhost:11434/v1
# GROUNDMEMORY_EMBEDDING__API_KEY=sk-...
# GROUNDMEMORY_EMBEDDING__MODEL=text-embedding-3-small

# Number of texts per embedding API call
# GROUNDMEMORY_EMBEDDING__BATCH_SIZE=64

# ---------------------------------------------------------------------------
# Search
# ---------------------------------------------------------------------------

# Number of results returned by memory_search
# GROUNDMEMORY_SEARCH__TOP_K=6

# Oversampling factor (candidates = top_k * candidate_multiplier per path)
# GROUNDMEMORY_SEARCH__CANDIDATE_MULTIPLIER=4

# Weight for vector similarity vs. BM25 keyword score (0.0-1.0)
# 0.0 = pure keyword, 1.0 = pure vector
# GROUNDMEMORY_SEARCH__VECTOR_WEIGHT=0.7

# Temporal decay rate per day (0.0 = disabled)
# score *= exp(-decay_rate * days_old)
# GROUNDMEMORY_SEARCH__TEMPORAL_DECAY_RATE=0.0

# MMR diversity lambda (0.0 = disabled, 1.0 = maximum diversity)
# GROUNDMEMORY_SEARCH__MMR_LAMBDA=0.0

# ---------------------------------------------------------------------------
# Chunking
# ---------------------------------------------------------------------------

# Target chunk size in approximate tokens (1 token ~= 4 chars)
# GROUNDMEMORY_CHUNKING__TOKENS=400

# Overlap between consecutive chunks in approximate tokens
# GROUNDMEMORY_CHUNKING__OVERLAP=80

# ---------------------------------------------------------------------------
# Bootstrap (system-prompt injection)
# ---------------------------------------------------------------------------

# Max characters per file before a truncation warning is added
# GROUNDMEMORY_BOOTSTRAP__MAX_CHARS_PER_FILE=20000

# Max total characters across all injected files
# GROUNDMEMORY_BOOTSTRAP__MAX_TOTAL_CHARS=150000

# Which files to inject into the system prompt at session start
# GROUNDMEMORY_BOOTSTRAP__INJECT_LONG_TERM_MEMORY=true
# GROUNDMEMORY_BOOTSTRAP__INJECT_USER_PROFILE=true
# GROUNDMEMORY_BOOTSTRAP__INJECT_AGENTS=true
# GROUNDMEMORY_BOOTSTRAP__INJECT_DAILY_LOGS=true
# GROUNDMEMORY_BOOTSTRAP__INJECT_RELATIONS=true

# Reconcile the SQLite relations table from RELATIONS.md at session start.
# Enable this if you edit RELATIONS.md manually outside the agent (e.g. in a
# text editor or via git) so that changes are reflected at the next session start.
# Disabled by default - the agent keeps both stores in sync automatically.
# GROUNDMEMORY_BOOTSTRAP__SYNC_RELATIONS_ON_BOOTSTRAP=false

# ---------------------------------------------------------------------------
# Compaction (pre-context-window-flush hooks)
# ---------------------------------------------------------------------------

# Enable compaction detection hooks
# GROUNDMEMORY_COMPACTION__ENABLED=true

# Tokens remaining in context window that trigger a flush suggestion
# GROUNDMEMORY_COMPACTION__SOFT_THRESHOLD_TOKENS=4000

# Minimum tokens always kept free for model responses
# GROUNDMEMORY_COMPACTION__RESERVE_FLOOR_TOKENS=20000
